{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.healthos.local/data/PatientRef.schema.json",
  "title": "PatientRef",
  "description": "A safe patient reference scoped to an organization and identity boundary.",
  "type": "object",
  "required": [
    "version",
    "patient_ref",
    "pseudonymous_id",
    "organization_ref",
    "identity_scope",
    "data_region",
    "created_at"
  ],
  "properties": {
    "version": { "type": "string", "const": "0.1.0" },
    "patient_ref": { "type": "string", "minLength": 1 },
    "pseudonymous_id": { "type": "string", "minLength": 1 },
    "organization_ref": { "type": "string", "minLength": 1 },
    "identity_scope": { "type": "string", "minLength": 1 },
    "data_region": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
