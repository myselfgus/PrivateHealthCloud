{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.healthos.local/integrations/CapabilityRequest.schema.json",
  "title": "CapabilityRequest",
  "description": "A request to execute a governed capability through a gateway.",
  "type": "object",
  "required": [
    "version",
    "request_id",
    "capability",
    "actor_ref",
    "organization_ref",
    "patient_ref",
    "purpose",
    "input_refs",
    "requested_outputs",
    "created_at"
  ],
  "properties": {
    "version": { "type": "string", "const": "0.1.0" },
    "request_id": { "type": "string", "minLength": 1 },
    "capability": { "type": "string", "minLength": 1 },
    "actor_ref": { "type": "string", "minLength": 1 },
    "organization_ref": { "type": "string", "minLength": 1 },
    "patient_ref": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "input_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "requested_outputs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "created_at": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
