{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.healthos.local/audit/AuditEvent.schema.json",
  "title": "AuditEvent",
  "description": "A governance or clinical audit event for a relevant operation.",
  "type": "object",
  "required": [
    "version",
    "audit_event_id",
    "event_type",
    "actor_ref",
    "organization_ref",
    "patient_ref",
    "target_ref",
    "governance_decision_ref",
    "outcome",
    "created_at"
  ],
  "properties": {
    "version": { "type": "string", "const": "0.1.0" },
    "audit_event_id": { "type": "string", "minLength": 1 },
    "event_type": { "type": "string", "minLength": 1 },
    "actor_ref": { "type": "string", "minLength": 1 },
    "organization_ref": { "type": "string", "minLength": 1 },
    "patient_ref": { "type": "string", "minLength": 1 },
    "target_ref": { "type": "string", "minLength": 1 },
    "governance_decision_ref": { "type": "string", "minLength": 1 },
    "outcome": {
      "type": "string",
      "enum": ["allowed", "denied", "degraded", "approval_required", "completed", "failed"]
    },
    "created_at": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
