{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.healthos.local/audit/ProvenanceRecord.schema.json",
  "title": "ProvenanceRecord",
  "description": "A record linking a generated artifact to sources, actor systems, models, agents, applications, and governance.",
  "type": "object",
  "required": [
    "version",
    "provenance_ref",
    "source_refs",
    "generated_by",
    "model_provider_ref",
    "agent_ref",
    "application_ref",
    "governance_decision_ref",
    "created_at"
  ],
  "properties": {
    "version": { "type": "string", "const": "0.1.0" },
    "provenance_ref": { "type": "string", "minLength": 1 },
    "source_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "generated_by": { "type": "string", "minLength": 1 },
    "model_provider_ref": { "type": ["string", "null"], "minLength": 1 },
    "agent_ref": { "type": ["string", "null"], "minLength": 1 },
    "application_ref": { "type": ["string", "null"], "minLength": 1 },
    "governance_decision_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
