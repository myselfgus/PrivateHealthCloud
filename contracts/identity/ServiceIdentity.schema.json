{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.healthos.local/identity/ServiceIdentity.schema.json",
  "title": "ServiceIdentity",
  "description": "A scoped identity for an internal service.",
  "type": "object",
  "required": [
    "version",
    "service_ref",
    "service_type",
    "organization_ref",
    "allowed_capabilities",
    "created_at"
  ],
  "properties": {
    "version": { "type": "string", "const": "0.1.0" },
    "service_ref": { "type": "string", "minLength": 1 },
    "service_type": { "type": "string", "minLength": 1 },
    "organization_ref": { "type": "string", "minLength": 1 },
    "allowed_capabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "created_at": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
