{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.healthos.local/models/ModelProviderManifest.schema.json",
  "title": "ModelProviderManifest",
  "description": "A manifest for governed model providers and their capability profile.",
  "type": "object",
  "required": [
    "version",
    "provider_ref",
    "provider_type",
    "runtime",
    "locality",
    "supports_phi",
    "supports_embeddings",
    "supports_transcription",
    "supports_llm",
    "requires_governance",
    "default_remote_allowed",
    "created_at"
  ],
  "properties": {
    "version": { "type": "string", "const": "0.1.0" },
    "provider_ref": { "type": "string", "minLength": 1 },
    "provider_type": { "type": "string", "minLength": 1 },
    "runtime": { "type": "string", "minLength": 1 },
    "locality": {
      "type": "string",
      "enum": ["local", "private_cloud", "external"]
    },
    "supports_phi": { "type": "boolean" },
    "supports_embeddings": { "type": "boolean" },
    "supports_transcription": { "type": "boolean" },
    "supports_llm": { "type": "boolean" },
    "requires_governance": { "type": "boolean" },
    "default_remote_allowed": { "type": "boolean" },
    "created_at": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
